# CoStudy Frontend – required environment variables
# Copy to .env and fill in values. See costudy-technical-audit.md for details.

# Supabase (required – no fallbacks)
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=

# Gemini API (used at build time for AI Deck / Teaching Deck)
GEMINI_API_KEY=

# Optional: CoStudy API base URL (default: https://api.costudy.in)
# VITE_COSTUDY_API_URL=
